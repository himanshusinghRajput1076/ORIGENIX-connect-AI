generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://origenix_admin:origenix_secure_password_88!@localhost:5432/origenix_connect_ai"
}

enum Role {
  ADMIN
  ANALYST
  USER
}

enum PersonRole {
  INVESTOR
  FOUNDER
  CO_FOUNDER
  VC
  ANGEL
  ENTREPRENEUR
}

enum FundingStage {
  PRE_SEED
  SEED
  SERIES_A
  SERIES_B
  SERIES_C
  GROWTH
  PUBLIC
}

enum LeadTemperature {
  HOT
  WARM
  COLD
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  EXPIRED
  ERROR
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  passwordHash  String
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leads                 Lead[]
  linkedInIntegrations  LinkedInIntegration[]
  auditLogs             AuditLog[]

  @@index([email])
}

model Company {
  id           String       @id @default(uuid())
  name         String       @unique
  tagline      String?
  description  String?      @db.Text
  stage        FundingStage @default(SEED)
  website      String?
  logo         String?
  location     String
  teamSize     Int          @default(1)
  totalFunding Float        @default(0)
  industries   String[]     // Array of industry tags
  foundedYear  Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  people       Person[]
  activities   ActivitySignal[]
  rounds       FundingRound[]

  @@index([name])
  @@index([stage])
  @@index([location])
}

model Person {
  id               String       @id @default(uuid())
  name             String
  title            String
  roles            PersonRole[]
  bio              String       @db.Text
  location         String
  companyName      String
  companyId        String?
  company          Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  email            String?      @unique
  website          String?
  linkedinUrl      String?      @unique
  twitterUrl       String?
  industries       String[]
  investmentMin    Float?
  investmentMax    Float?
  investmentCount  Int          @default(0)
  leadScore        Int          @default(50)
  leadTemp         LeadTemperature @default(WARM)
  tags             String[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  leads            Lead[]
  signals          ActivitySignal[]

  @@index([linkedinUrl])
  @@index([email])
  @@index([leadScore])
}

model FundingRound {
  id          String       @id @default(uuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stage       FundingStage
  amount      Float
  date        DateTime
  leadInvestor String?
  investors   String[]
  createdAt   DateTime     @default(now())

  @@index([companyId])
}

model ActivitySignal {
  id          String   @id @default(uuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  personId    String?
  person      Person?  @relation(fields: [personId], references: [id], onDelete: Cascade)
  type        String   // "post", "hiring", "funding", "launch"
  title       String
  description String   @db.Text
  sourceUrl   String?
  signalScore Int      @default(50)
  date        DateTime @default(now())

  @@index([companyId])
  @@index([personId])
  @@index([type])
}

model Lead {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  personId      String
  person        Person          @relation(fields: [personId], references: [id], onDelete: Cascade)
  status        String          @default("NEW") // "NEW", "CONTACTED", "REPLIED", "QUALIFIED", "CLOSED"
  aiScore       Int             @default(50)
  matchReason   String?         @db.Text
  notes         String?         @db.Text
  outreachDraft String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([userId, personId])
  @@index([userId])
  @@index([status])
}

model LinkedInIntegration {
  id                 String            @id @default(uuid())
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetProfileUrl   String            @default("https://www.linkedin.com/in/himanshusingh88")
  encryptedClientId  String
  encryptedSecret    String
  encryptedAccessToken String?
  status             IntegrationStatus @default(DISCONNECTED)
  scopes             String[]          @default(["r_liteprofile", "r_emailaddress", "w_member_social", "rw_organization"])
  lastSyncedAt       DateTime?
  expiresAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([userId, targetProfileUrl])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // e.g., "LINKEDIN_CONNECT", "OUTREACH_GENERATE", "API_KEY_REVOKE"
  details   String   @db.Text
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([action])
}
