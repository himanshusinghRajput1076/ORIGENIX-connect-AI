datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  USER
  VIEWER
}

enum CompanyType {
  STARTUP
  VC_FIRM
  ANGEL_SYNDICATE
  CORPORATE_VC
  ACCELERATOR
  FAMILY_OFFICE
  PE_FIRM
  ENTERPRISE
}

enum FundingStage {
  PRE_SEED
  SEED
  ANGEL
  SERIES_A
  SERIES_B
  SERIES_C
  SERIES_D_PLUS
  GROWTH
  PRE_IPO
  PUBLIC
  BOOTSTRAPPED
  ACQUIRED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum EntityType {
  COMPANY
  INVESTOR
  FOUNDER
  STARTUP
}

enum ContactStage {
  NEW
  CONTACTED
  MEETING_SCHEDULED
  TERM_SHEET
  CLOSED_WON
  CLOSED_LOST
}

enum LeadTemp {
  HOT
  WARM
  COLD
}

enum NotificationType {
  NEW_MATCH
  FUNDING_ALERT
  OUTREACH_REPLY
  SYSTEM
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String
  role         UserRole
  avatar       String?
  linkedinUrl  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  savedSearches SavedSearch[]
  crmNotes     CrmNote[]
  notifications Notification[]
  linkedInIntegrations LinkedInIntegration[]

  @@map("users")
}

model Company {
  id           String        @id @default(cuid())
  name         String
  tagline      String?
  description  String?
  type         CompanyType
  stage        FundingStage
  industries   String[]
  location     String
  website      String?
  linkedinUrl  String?
  foundedYear  Int?
  teamSize     Int?
  totalFunding Float?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  investors    Investor[]
  founders     Founder[]
  startups     Startup[]
  posts        CompanyPost[]
  aiAnalysis   AiAnalysis[]

  @@index([location])
  @@index([industries])
  @@index([stage])
  @@map("companies")
}

model Investor {
  id             String   @id @default(cuid())
  name           String
  title          String
  email          String?
  linkedinUrl    String?
  avatar         String?
  bio            String?
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  location       String
  industries     String[]
  investmentMin  Float?
  investmentMax  Float?
  investmentCount Int      @default(0)
  matchScore     Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId])
  @@index([location])
  @@index([industries])
  @@map("investors")
}

model Founder {
  id               String   @id @default(cuid())
  name             String
  title            String
  email            String?
  linkedinUrl      String?
  avatar           String?
  bio              String?
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])
  location         String
  industries       String[]
  foundedCompanies String[]
  leadScore        Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId])
  @@index([location])
  @@index([industries])
  @@map("founders")
}

model Startup {
  id             String       @id @default(cuid())
  companyId      String       @unique
  company        Company      @relation(fields: [companyId], references: [id])
  fundingRaised  Float        @default(0)
  targetRaise    Float?
  currentStage   FundingStage
  pitchDeckUrl   String?
  tractionMetrics Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([companyId])
  @@index([currentStage])
  @@map("startups")
}

model CompanyPost {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  title       String
  content     String
  source      String
  sourceUrl   String?
  publishedAt DateTime
  sentiment   Sentiment?
  createdAt   DateTime   @default(now())

  @@index([companyId])
  @@map("company_posts")
}

model AiAnalysis {
  id          String     @id @default(cuid())
  entityId    String
  entityType  EntityType
  analysisType String
  result      Json
  confidence  Float
  generatedAt DateTime   @default(now())
  companyId   String?
  company     Company?   @relation(fields: [companyId], references: [id])

  @@index([entityId])
  @@index([entityType])
  @@index([companyId])
  @@map("ai_analyses")
}

model Contact {
  id          String       @id @default(cuid())
  name        String
  email       String?
  phone       String?
  linkedinUrl String?
  companyName String?
  notes       String?
  stage       ContactStage
  leadScore   Float        @default(0)
  temperature LeadTemp
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  crmNotes    CrmNote[]

  @@index([email])
  @@index([companyName])
  @@map("contacts")
}

model CrmNote {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([userId])
  @@map("crm_notes")
}

model SavedSearch {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  query       String
  filters     Json
  notifyOnNew Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("saved_searches")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@map("notifications")
}

model LinkedInIntegration {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  targetProfileUrl  String
  encryptedClientId String
  encryptedSecret   String
  scopes            String[]
  status            String   @default("CONNECTED")
  lastSyncedAt      DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, targetProfileUrl])
  @@index([userId])
  @@map("linkedin_integrations")
}

